    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "drag-drop-touch": "^1.3.1",
    "firebase": "^12.8.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
