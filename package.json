{
  "name": "reuniao-vida-ministerio",
  "private": true,
  "version": "4.8.263",
  "type": "module",
  "scripts": {
    "predev": "npm version patch --no-git-tag-version",
    "predeploy": "npm version patch --no-git-tag-version",
    "predeploy:all": "npm version patch --no-git-tag-version",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && firebase deploy --project rvm-palmas-pr --only hosting",
    "deploy:rules": "firebase deploy --project rvm-palmas-pr --only firestore:rules",
    "deploy:indexes": "firebase deploy --project rvm-palmas-pr --only firestore:indexes",
    "deploy:all": "npm run build && firebase deploy --project rvm-palmas-pr",
    "firebase:new:deploy:rules": "firebase deploy --project rvm-palmas-pr --only firestore:rules",
    "firebase:new:deploy:indexes": "firebase deploy --project rvm-palmas-pr --only firestore:indexes",
    "firebase:new:deploy:hosting": "npm run build && firebase deploy --project rvm-palmas-pr --only hosting",
    "firebase:new:deploy:all": "npm run build && firebase deploy --project rvm-palmas-pr",
    "migrate:auth:dry": "node scripts/firebase-migration/migrate-auth-users.mjs --dry-run",
    "migrate:auth": "node scripts/firebase-migration/migrate-auth-users.mjs --execute --yes",
    "migrate:firestore:dry": "node scripts/firebase-migration/migrate-firestore.mjs --dry-run",
    "migrate:firestore": "node scripts/firebase-migration/migrate-firestore.mjs --execute --yes",
    "migrate:indexes:dry": "node scripts/firebase-migration/migrate-indexes.mjs --dry-run",
    "migrate:indexes": "node scripts/firebase-migration/migrate-indexes.mjs --execute --yes",
    "migrate:verify": "node scripts/firebase-migration/verify-target.mjs"
